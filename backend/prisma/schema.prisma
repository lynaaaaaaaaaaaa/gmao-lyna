generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model affectation_technicien {
  idAffectation  Int  @id @default(autoincrement())
  tempsTravail   Int?
  idTechnicien   Int?
  idIntervention Int?

  technicien   technicien?   @relation(fields: [idTechnicien], references: [idTechnicien], onDelete: Restrict, onUpdate: Restrict, map: "affectation_technicien_ibfk_1")
  intervention intervention? @relation(fields: [idIntervention], references: [idIntervention], onDelete: Restrict, onUpdate: Restrict, map: "affectation_technicien_ibfk_2")

  @@index([idIntervention], map: "idIntervention")
  @@index([idTechnicien], map: "idTechnicien")
}

model article {
  idArticle    Int      @id @default(autoincrement())
  reference    String?  @unique @db.VarChar(50)
  designation  String?  @db.VarChar(150)
  description  String?  @db.Text
  prixUnitaire Decimal? @db.Decimal(10, 2)

  idFamille      Int?
  idUniteArticle Int?
  idModele       Int?

  gereEnStock Boolean @default(true)
  serialise   Boolean @default(false)
  reparable   Boolean @default(false)
  actif       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  famille      famille?       @relation(fields: [idFamille], references: [idFamille], onDelete: SetNull, onUpdate: Restrict)
  uniteArticle unite_article? @relation(fields: [idUniteArticle], references: [idUniteArticle], onDelete: SetNull, onUpdate: Restrict)
  modele       modele?        @relation(fields: [idModele], references: [idModele], onDelete: SetNull, onUpdate: Restrict)

   consommations   consommation[]
  materiels       materiel[]
  etatMateriels   etat_materiel[]
  stocks          stock_article_magasin[]
  mouvementsStock mouvement_stock[]
  lignesEntreeStock entree_stock_ligne[]
  lignesSortieStock sortie_stock_ligne[]
  lignesInventairePrepare LigneInventairePrepare[]
  reservationsStock reservation_stock[]
  lignesDemandesTransfert ligne_demande_transfert_stock[]
  lignes_reapprovisionnement ligne_reapprovisionnement[] @relation("ArticleLignesReapprovisionnement")

  @@index([idFamille])
  @@index([idUniteArticle])
  @@index([idModele])
}

model consommation {
  idConsommation Int      @id @default(autoincrement())
  quantite       Int?
  coutTotal      Decimal? @db.Decimal(10, 2)
  idArticle      Int?
  idIntervention Int?

  article      article?      @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict, onUpdate: Restrict, map: "consommation_ibfk_1")
  intervention intervention? @relation(fields: [idIntervention], references: [idIntervention], onDelete: Restrict, onUpdate: Restrict, map: "consommation_ibfk_2")

  @@index([idArticle], map: "idArticle")
  @@index([idIntervention], map: "idIntervention")
}

model unite_article {
  idUniteArticle Int    @id @default(autoincrement())
  code           String @unique @db.VarChar(20)
  libelle        String @db.VarChar(100)

  articles article[]

  @@map("unite_article")
}

model demande_intervention {
  idDemande   Int       @id @default(autoincrement())
  dateDemande DateTime? @db.Date
  description String?   @db.Text
  statut      String?   @db.VarChar(50)
  idMateriel  Int?

  materiel     materiel?      @relation(fields: [idMateriel], references: [idMateriel], onDelete: Restrict, onUpdate: Restrict, map: "demande_intervention_ibfk_1")
  intervention intervention[]

  @@index([idMateriel], map: "idMateriel")
}

model etat_materiel {
  idEtat    Int      @id @default(autoincrement())
  libelle   String?  @db.VarChar(100)
  idArticle Int?
  article   article? @relation(fields: [idArticle], references: [idArticle])

  materiel materiel[]
}

model etat_modele {
  idEtat  Int     @id
  libelle String? @db.VarChar(100)

  modele modele[]
}

model famille {
  idFamille Int     @id @default(autoincrement())
  code      String? @db.VarChar(50)
  libelle   String? @db.VarChar(100)
  parent_id Int?

  famille       famille?  @relation("familleTofamille", fields: [parent_id], references: [idFamille], onDelete: Restrict, onUpdate: Restrict, map: "famille_ibfk_parent")
  other_famille famille[] @relation("familleTofamille")

  modele   modele[]
  articles article[]

  @@index([parent_id], map: "famille_ibfk_parent")
}

model gamme {
  idGamme         Int      @id @default(autoincrement())
  code            String?  @db.VarChar(50)
  libelle         String?  @db.VarChar(100)
  typeMaintenance String?  @db.VarChar(50)
  actif           Boolean?
  idModele        Int?

  modele          modele?           @relation(fields: [idModele], references: [idModele], onDelete: Restrict, onUpdate: Restrict, map: "gamme_ibfk_1")
  gamme_operation gamme_operation[]
  intervention    intervention[]

  @@index([idModele], map: "idModele")
}

model gamme_operation {
  idOperation   Int     @id @default(autoincrement())
  ordre         Int?
  libelle       String? @db.VarChar(100)
  tempsStandard Int?
  idGamme       Int?

  gamme gamme? @relation(fields: [idGamme], references: [idGamme], onDelete: Restrict, onUpdate: Restrict, map: "gamme_operation_ibfk_1")

  @@index([idGamme], map: "idGamme")
}

model intervention {
  idIntervention  Int       @id @default(autoincrement())
  code            String?   @db.VarChar(50)
  typeMaintenance String?   @db.VarChar(50)
  dateDebut       DateTime? @db.Date
  dateFin         DateTime? @db.Date
  etat            String?   @db.VarChar(50)
  idMateriel      Int?
  idDemande       Int?
  idGamme         Int?

  affectation_technicien affectation_technicien[]
  consommations          consommation[]
  operation_intervention operation_intervention[]

  materiel             materiel?             @relation(fields: [idMateriel], references: [idMateriel], onDelete: Restrict, onUpdate: Restrict, map: "intervention_ibfk_1")
  demande_intervention demande_intervention? @relation(fields: [idDemande], references: [idDemande], onDelete: Restrict, onUpdate: Restrict, map: "intervention_ibfk_2")
  gamme                gamme?                @relation(fields: [idGamme], references: [idGamme], onDelete: Restrict, onUpdate: Restrict, map: "intervention_ibfk_3")

  @@index([idDemande], map: "idDemande")
  @@index([idGamme], map: "idGamme")
  @@index([idMateriel], map: "idMateriel")
}

model materiel {
  idMateriel      Int       @id @default(autoincrement())
  code            String?   @unique @db.VarChar(50)
  numeroSerie     String?   @unique @db.VarChar(100)
  dateMiseService DateTime? @db.Date

  idArticle          Int?
  idModele           Int?
  idEtat             Int?
  idType             Int?
  idPointStructure   Int?
  idLigneEntreeStock Int?

  actif Boolean? @default(true)

  article         article?         @relation(fields: [idArticle], references: [idArticle], onDelete: SetNull, onUpdate: Restrict)
  modele          modele?          @relation(fields: [idModele], references: [idModele], onDelete: Restrict, onUpdate: Restrict, map: "materiel_ibfk_1")
  etat_materiel   etat_materiel?   @relation(fields: [idEtat], references: [idEtat], onDelete: Restrict, onUpdate: Restrict, map: "materiel_ibfk_2")
  type_materiel   type_materiel?   @relation(fields: [idType], references: [idType], onDelete: Restrict, onUpdate: Restrict, map: "materiel_ibfk_3")

  point_structure point_structure? @relation("PointStructureMateriels", fields: [idPointStructure], references: [idPoint], onDelete: SetNull, onUpdate: Restrict)

  entreeStockLigne entree_stock_ligne? @relation(fields: [idLigneEntreeStock], references: [idLigneEntreeStock], onDelete: SetNull)
  lignesSortieStock sortie_stock_ligne[]

  demande_intervention demande_intervention[]
  intervention         intervention[]
  mouvementsStock      mouvement_stock[]
  lignesInventairePrepare LigneInventairePrepare[]

  @@index([idArticle])
  @@index([idEtat], map: "idEtat")
  @@index([idModele], map: "idModele")
  @@index([idType], map: "idType")
  @@index([idPointStructure])
  @@index([idLigneEntreeStock])
}

model magasin {
  idMagasin Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  libelle   String   @db.VarChar(100)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

inventairesPrepares InventairePrepare[]

  stocks           stock_article_magasin[]
  mouvementsSource mouvement_stock[]       @relation("MagasinSource")
  mouvementsDest   mouvement_stock[]       @relation("MagasinDestination")

  emplacements      emplacement_magasin[]
  lignesEntreeStock entree_stock_ligne[]
  lignesSortieStock sortie_stock_ligne[]
  reservationsStock reservation_stock[]
  demandesTransfertSource      demande_transfert_stock[] @relation("DemandeTransfertSource")
demandesTransfertDestination demande_transfert_stock[] @relation("DemandeTransfertDestination")
demandes_reapprovisionnement demande_reapprovisionnement[] @relation("MagasinDemandesReapprovisionnement")
  
}

model stock_article_magasin {
  idStock Int @id @default(autoincrement())

  idArticle Int
  idMagasin Int

  quantitePhysique   Decimal @default(0) @db.Decimal(10, 2)
  quantiteReservee   Decimal @default(0) @db.Decimal(10, 2)
  quantiteDisponible Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article article @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)
  magasin magasin @relation(fields: [idMagasin], references: [idMagasin], onDelete: Restrict)

  @@unique([idArticle, idMagasin])
  @@index([idArticle])
  @@index([idMagasin])
}

model mouvement_stock {
  idMouvement Int @id @default(autoincrement())

  typeMouvement String   @db.VarChar(50) // ENTREE | SORTIE | TRANSFERT | INVENTAIRE
  dateMouvement DateTime @default(now())

  quantite Decimal @db.Decimal(10, 2)

  idArticle  Int
  idMateriel Int?

  idMagasinSource      Int?
  idMagasinDestination Int?

  origineType String? @db.VarChar(50) // RECEPTION | INTERVENTION | TRANSFERT
  origineId   Int?

  commentaire String? @db.Text

  article  article   @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)
  materiel materiel? @relation(fields: [idMateriel], references: [idMateriel], onDelete: SetNull)

  magasinSource      magasin? @relation("MagasinSource", fields: [idMagasinSource], references: [idMagasin], onDelete: SetNull)
  magasinDestination magasin? @relation("MagasinDestination", fields: [idMagasinDestination], references: [idMagasin], onDelete: SetNull)

  @@index([idArticle])
  @@index([idMateriel])
  @@index([idMagasinSource])
  @@index([idMagasinDestination])
}

model modele {
  idModele  Int     @id @default(autoincrement())
  code      String? @db.VarChar(50)
  libelle   String? @db.VarChar(100)
  idFamille Int?
  idEtat    Int

  gamme    gamme[]
  materiel materiel[]
  articles article[]

  famille     famille?    @relation(fields: [idFamille], references: [idFamille], onDelete: Restrict, onUpdate: Restrict, map: "modele_ibfk_1")
  etat_modele etat_modele @relation(fields: [idEtat], references: [idEtat], onUpdate: Restrict, map: "modele_ibfk_2")

  @@index([idFamille], map: "idFamille")
  @@index([idEtat], map: "modele_ibfk_2")
}

model operation_intervention {
  idOperation    Int     @id @default(autoincrement())
  ordre          Int?
  libelle        String? @db.VarChar(100)
  tempsPasse     Int?
  idIntervention Int?

  intervention intervention? @relation(fields: [idIntervention], references: [idIntervention], onDelete: Restrict, onUpdate: Restrict, map: "operation_intervention_ibfk_1")

  @@index([idIntervention], map: "idIntervention")
}
model point_structure {
  idPoint     Int      @id @default(autoincrement())
  code        String?  @unique @db.VarChar(50)
  libelle     String?  @db.VarChar(100)
  description String?  @db.Text
  typePoint   String   @db.VarChar(30)
  actif       Boolean? @default(true)

  materiels materiel[] @relation("PointStructureMateriels")
}

model technicien {
  idTechnicien Int     @id @default(autoincrement())
  matricule    String? @db.VarChar(50)
  nom          String? @db.VarChar(100)

  affectation_technicien affectation_technicien[]
}

model type_materiel {
  idType  Int     @id @default(autoincrement())
  libelle String? @db.VarChar(100)

  materiel materiel[]
}

model lien_arborescence {
  idLien Int @id @default(autoincrement())

  typeArborescence String @db.VarChar(30)

  parentType       String @db.VarChar(30)
  parentPointId    Int?
  parentMaterielId Int?

  enfantType       String @db.VarChar(30)
  enfantPointId    Int?
  enfantMaterielId Int?

  ordre     Int?
  actif     Boolean? @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeArborescence], map: "idx_type_arborescence")
  @@index([parentPointId], map: "idx_parent_point")
  @@index([parentMaterielId], map: "idx_parent_materiel")
  @@index([enfantPointId], map: "idx_enfant_point")
  @@index([enfantMaterielId], map: "idx_enfant_materiel")
}
model entree_stock {
  idEntreeStock Int @id @default(autoincrement())

  numero        String   @unique @db.VarChar(50)
  dateReception DateTime
  commentaire   String?  @db.Text
  statut        String   @default("VALIDEE") @db.VarChar(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lignes entree_stock_ligne[]

  @@index([numero])
}

model entree_stock_ligne {
  idLigneEntreeStock Int @id @default(autoincrement())

  idEntreeStock Int
  idArticle     Int
  idMagasin     Int
  idEmplacement Int?

  quantite     Decimal   @db.Decimal(10, 2)
  prixUnitaire Decimal?  @db.Decimal(10, 2)
  numeroLot    String?   @db.VarChar(100)
  datePeremption DateTime?
  commentaire  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entreeStock entree_stock @relation(fields: [idEntreeStock], references: [idEntreeStock], onDelete: Cascade)
  article     article      @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)
  magasin     magasin      @relation(fields: [idMagasin], references: [idMagasin], onDelete: Restrict)
  emplacement emplacement_magasin? @relation(fields: [idEmplacement], references: [idEmplacement], onDelete: SetNull)

  materiels materiel[]

  @@index([idEntreeStock])
  @@index([idArticle])
  @@index([idMagasin])
  @@index([idEmplacement])
}

model sortie_stock {
  idSortieStock Int @id @default(autoincrement())

  numero      String   @unique @db.VarChar(50)
  dateSortie  DateTime
  commentaire String?  @db.Text
  statut      String   @default("VALIDEE") @db.VarChar(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lignes sortie_stock_ligne[]

  @@index([numero])
}

model sortie_stock_ligne {
  idLigneSortieStock Int @id @default(autoincrement())

  idSortieStock Int
  idArticle     Int
  idMagasin     Int
  idEmplacement Int?
  idMateriel    Int?

  quantite     Decimal  @db.Decimal(10, 2)
  prixUnitaire Decimal? @db.Decimal(10, 2)
  commentaire  String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sortieStock sortie_stock @relation(fields: [idSortieStock], references: [idSortieStock], onDelete: Cascade)
  article     article      @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)
  magasin     magasin      @relation(fields: [idMagasin], references: [idMagasin], onDelete: Restrict)
  emplacement emplacement_magasin? @relation(fields: [idEmplacement], references: [idEmplacement], onDelete: SetNull)
  materiel    materiel?    @relation(fields: [idMateriel], references: [idMateriel], onDelete: SetNull)

  @@index([idSortieStock])
  @@index([idArticle])
  @@index([idMagasin])
  @@index([idEmplacement])
  @@index([idMateriel])
}

model emplacement_magasin {
  idEmplacement Int @id @default(autoincrement())

  idMagasin Int
  code      String @db.VarChar(50)
  libelle   String @db.VarChar(100)
  actif     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  magasin magasin @relation(fields: [idMagasin], references: [idMagasin], onDelete: Cascade)

  lignesEntreeStock entree_stock_ligne[]
  lignesSortieStock sortie_stock_ligne[]

  @@unique([idMagasin, code])
  @@index([idMagasin])
}
enum StatutInventaire {
  BROUILLON
  EN_COMPTAGE
  VALIDE
  ANNULE
}

model InventairePrepare {
  idInventairePrepare Int      @id @default(autoincrement())
  numero               String   @unique @db.VarChar(50)

  dateCreation   DateTime  @default(now())
  dateComptage   DateTime?
  dateValidation DateTime?

  idMagasin Int
  magasin   magasin @relation(fields: [idMagasin], references: [idMagasin], onDelete: Restrict)

  statut      StatutInventaire @default(BROUILLON)
  commentaire String?          @db.Text

  lignes LigneInventairePrepare[]

  @@index([idMagasin])
  @@index([statut])
  @@map("inventaire_prepare")
}

model LigneInventairePrepare {
  idLigneInventairePrepare Int @id @default(autoincrement())

  idInventairePrepare Int
  inventairePrepare   InventairePrepare @relation(fields: [idInventairePrepare], references: [idInventairePrepare], onDelete: Cascade)

  idArticle Int
  article   article @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)

  idMateriel Int?
  materiel   materiel? @relation(fields: [idMateriel], references: [idMateriel], onDelete: SetNull)

  quantiteTheorique Decimal  @default(0) @db.Decimal(10, 2)
  quantiteReelle    Decimal? @db.Decimal(10, 2)
  ecart             Decimal? @db.Decimal(10, 2)

  commentaire String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([idInventairePrepare])
  @@index([idArticle])
  @@index([idMateriel])
  @@map("ligne_inventaire_prepare")
}
model reservation_stock {
  idReservationStock Int @id @default(autoincrement())

  numero          String   @unique @db.VarChar(50)
  dateReservation DateTime @default(now())
  dateAnnulation  DateTime?

  statut String @default("VALIDEE") @db.VarChar(30)
  
  idArticle Int
  idMagasin Int

  quantite Decimal @db.Decimal(10, 2)

  demandeur   String? @db.VarChar(100)
  origineType String? @db.VarChar(50)
  origineId   Int?
  commentaire String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article article @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)
  magasin magasin @relation(fields: [idMagasin], references: [idMagasin], onDelete: Restrict)

  @@index([idArticle])
  @@index([idMagasin])
  @@index([statut])
}
model demande_transfert_stock {
  idDemandeTransfertStock Int @id @default(autoincrement())

  numero       String   @unique @db.VarChar(50)
  dateDemande  DateTime @default(now())
  dateValidation DateTime?
  dateExecution  DateTime?
  dateAnnulation DateTime?

  statut String @default("EN_ATTENTE") @db.VarChar(30)

  idMagasinSource      Int
  idMagasinDestination Int

  demandeur   String? @db.VarChar(100)
  commentaire String? @db.Text

  magasinSource magasin @relation("DemandeTransfertSource", fields: [idMagasinSource], references: [idMagasin], onDelete: Restrict)
  magasinDestination magasin @relation("DemandeTransfertDestination", fields: [idMagasinDestination], references: [idMagasin], onDelete: Restrict)

  lignes ligne_demande_transfert_stock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([idMagasinSource])
  @@index([idMagasinDestination])
  @@index([statut])
}

model ligne_demande_transfert_stock {
  idLigneDemandeTransfertStock Int @id @default(autoincrement())

  idDemandeTransfertStock Int
  idArticle Int

  quantite Decimal @db.Decimal(10, 2)
  commentaire String? @db.Text

  demandeTransfert demande_transfert_stock @relation(fields: [idDemandeTransfertStock], references: [idDemandeTransfertStock], onDelete: Cascade)
  article article @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([idDemandeTransfertStock, idArticle])
  @@index([idDemandeTransfertStock])
  @@index([idArticle])
}
model demande_reapprovisionnement {
  idDemandeReapprovisionnement Int @id @default(autoincrement())

  numero        String   @unique @db.VarChar(50)
  dateDemande   DateTime @default(now())
  dateValidation DateTime?
  dateAnnulation DateTime?

  statut      String  @default("BROUILLON") @db.VarChar(30)
  demandeur   String? @db.VarChar(150)
  commentaire String? @db.Text

  idMagasin Int
  magasin   magasin @relation("MagasinDemandesReapprovisionnement", fields: [idMagasin], references: [idMagasin])

  lignes ligne_reapprovisionnement[]

  @@index([idMagasin])
  @@map("demande_reapprovisionnement")
}

model ligne_reapprovisionnement {
  idLigneReapprovisionnement Int @id @default(autoincrement())

  idDemandeReapprovisionnement Int
  demande demande_reapprovisionnement @relation(fields: [idDemandeReapprovisionnement], references: [idDemandeReapprovisionnement], onDelete: Cascade)

  idArticle Int
  article article @relation("ArticleLignesReapprovisionnement", fields: [idArticle], references: [idArticle])

  quantiteDemandee Decimal @db.Decimal(10, 2)
  commentaire      String? @db.Text

  @@index([idDemandeReapprovisionnement])
  @@index([idArticle])
  @@map("ligne_reapprovisionnement")
}