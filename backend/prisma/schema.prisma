generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model affectation_technicien {
  idAffectation   Int           @id @default(autoincrement())
  tempsTravail    Int?
  idTechnicien    Int?
  idIntervention  Int?
  affectePar      String?       @db.VarChar(100)
  dateAffectation DateTime?     @default(now()) @db.DateTime(0)
  technicien      technicien?   @relation(fields: [idTechnicien], references: [idTechnicien], onDelete: Restrict, onUpdate: Restrict, map: "affectation_technicien_ibfk_1")
  intervention    intervention? @relation(fields: [idIntervention], references: [idIntervention], onDelete: Restrict, onUpdate: Restrict, map: "affectation_technicien_ibfk_2")

  @@index([idIntervention], map: "idIntervention")
  @@index([idTechnicien], map: "idTechnicien")
}

model article {
  idArticle Int @id @default(autoincrement())

  reference   String? @unique @db.VarChar(50)
  designation String? @db.VarChar(150)
  description String? @db.Text

  etatArticle String            @default("ACTIF") @db.VarChar(30)
  categorie   CategorieArticle? @default(PIECE_RECHANGE)

  idFamille      Int?
  idUniteArticle Int?

  // Compatibilité ancienne logique article -> modele
  idModele Int?

  fournisseurPrincipal String? @db.VarChar(150)
  fabricantArticle     String? @db.VarChar(150)
  referenceFabricant   String? @db.VarChar(100)
  nbDecimales          Int     @default(0)
  codeBarres           String? @db.VarChar(100)

  centreCout    String? @db.VarChar(100)
  budget        String? @db.VarChar(100)
  codeComptable String? @db.VarChar(100)
  natureAchat   String? @db.VarChar(100)
  taxe          String? @db.VarChar(50)

  // Compatibilité ancien stock
  prixUnitaire Decimal? @db.Decimal(10, 2)

  // Version améliorée
  prixStandard     Decimal? @db.Decimal(10, 2)
  prixMoyenPondere Decimal? @db.Decimal(10, 2)

  estModele   Boolean @default(false)
  gereEnStock Boolean @default(true)
  gereParLot  Boolean @default(false)
  serialise   Boolean @default(false)

  reparable Boolean @default(false)
  actif     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  createdBy String?  @db.VarChar(100)
  updatedBy String?  @db.VarChar(100)

  famille      famille?       @relation(fields: [idFamille], references: [idFamille], onDelete: SetNull, onUpdate: Restrict)
  uniteArticle unite_article? @relation(fields: [idUniteArticle], references: [idUniteArticle], onDelete: SetNull, onUpdate: Restrict)

  // Ancienne relation compatible
  modele modele? @relation("ArticleModeleCompat", fields: [idModele], references: [idModele], onDelete: SetNull, onUpdate: Restrict)

  // Nouvelle relation propre article modèle -> modèle équipement
  modeleEquipement modele? @relation("ArticleModele")

  consommations              consommation[]
  stocks                     stock_article_magasin[]
  mouvementsStock            mouvement_stock[]
  lignesEntreeStock          entree_stock_ligne[]
  lignesSortieStock          sortie_stock_ligne[]
  lignesInventairePrepare    LigneInventairePrepare[]
  reservationsStock          reservation_stock[]
  lignesDemandesTransfert    ligne_demande_transfert_stock[]
  lignes_reapprovisionnement ligne_reapprovisionnement[]     @relation("ArticleLignesReapprovisionnement")
  fournituresIntervention    fourniture_intervention[]

  @@index([idFamille])
  @@index([idUniteArticle])
  @@index([idModele])
  @@index([categorie])
  @@index([etatArticle])
  @@index([estModele])
  @@index([gereEnStock])
  @@index([serialise])
  @@index([actif])
}

enum CategorieArticle {
  PIECE_RECHANGE
  CONSOMMABLE
  FOURNITURE
  OUTILLAGE
  EQUIPEMENT_STOCKE
  SERVICE
  AUTRE
}

enum CriticiteModele {
  FAIBLE
  MOYENNE
  ELEVEE
  CRITIQUE
}

enum NiveauMaintenance {
  NIVEAU_1
  NIVEAU_2
  NIVEAU_3
  NIVEAU_4
  NIVEAU_5
}

model consommation {
  idConsommation Int @id @default(autoincrement())

  quantite          Decimal  @db.Decimal(10, 2)
  prixUnitaire      Decimal? @db.Decimal(10, 2)
  coutTotal         Decimal? @db.Decimal(10, 2)
  quantiteRetournee Decimal  @default(0.00) @db.Decimal(10, 2)

  statut      String  @default("ACTIVE") @db.VarChar(30)
  commentaire String? @db.Text

  idArticle          Int
  idIntervention     Int
  idMagasin          Int?
  idSortieStockLigne Int?

  createdBy String?  @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cancelledBy     String?   @db.VarChar(100)
  cancelledAt     DateTime?
  motifAnnulation String?   @db.Text

  article      article      @relation(fields: [idArticle], references: [idArticle], onDelete: Restrict)
  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Restrict)
  magasin      magasin?     @relation(fields: [idMagasin], references: [idMagasin], onDelete: SetNull)

  sortieStockLigne sortie_stock_ligne? @relation(fields: [idSortieStockLigne], references: [idLigneSortieStock], onDelete: SetNull)

  @@index([idArticle])
  @@index([idIntervention])
  @@index([idMagasin])
  @@index([idSortieStockLigne])
  @@index([statut])
}

model unite_article {
  idUniteArticle Int       @id @default(autoincrement())
  code           String    @unique @db.VarChar(20)
  libelle        String    @db.VarChar(100)
  articles       article[]

  @@map("unite_article")
}

model demande_intervention {
  idDemande Int @id @default(autoincrement())

  code        String?   @unique @db.VarChar(50)
  dateDemande DateTime? @db.DateTime(0)

  description String? @db.Text
  statut      String? @default("EN_PREPARATION") @db.VarChar(50)

  idMateriel Int?

  createdBy String? @db.VarChar(100)
  demandeur String? @db.VarChar(100)

  dateSoumission DateTime? @db.DateTime(0)
  dateValidation DateTime? @db.DateTime(0)

  motifRefus String? @db.Text
  priorite   String? @default("NORMALE") @db.VarChar(30)
  criticite  String? @default("MOYENNE") @db.VarChar(30)

  validatedBy String? @db.VarChar(100)

  // DI : infos qui initialisent l'OT
  receptionTravaux     Boolean @default(false)
  materielEnPanne      Boolean @default(false)
  materielIndisponible Boolean @default(false)

  // Réception travaux côté DI
  dateReceptionTravaux DateTime? @db.DateTime(0)
  receptionBy          String?   @db.VarChar(100)
  motifRefusTravaux    String?   @db.Text

  createdAt DateTime @default(now()) @db.DateTime(0)
  updatedAt DateTime @default(now()) @updatedAt @db.DateTime(0)

  materiel     materiel?      @relation(fields: [idMateriel], references: [idMateriel], onDelete: Restrict, onUpdate: Restrict, map: "demande_intervention_ibfk_1")
  intervention intervention[]

  historiquesEtat historique_etat_demande_intervention[]

  @@index([idMateriel], map: "idMateriel")
  @@index([statut])
  @@index([priorite])
}

model etat_materiel {
  idEtat   Int        @id @default(autoincrement())
  libelle  String?    @db.VarChar(100)
  code     String?    @unique @db.VarChar(50)
  materiel materiel[]
}

model etat_modele {
  idEtat  Int      @id
  libelle String?  @db.VarChar(100)
  modele  modele[]
}

model famille {
  idFamille                  Int                          @id @default(autoincrement())
  code                       String?                      @db.VarChar(50)
  libelle                    String?                      @db.VarChar(100)
  parent_id                  Int?
  actif                      Boolean                      @default(true)
  natureAchat                NatureAchatFamille?
  typeFamille                TypeFamille                  @default(EQUIPEMENT)
  articles                   article[]
  famille                    famille?                     @relation("familleTofamille", fields: [parent_id], references: [idFamille])
  other_famille              famille[]                    @relation("familleTofamille")
  gamme_operation            gamme_operation[]            @relation("GammeOperationFamille")
  modele                     modele[]
  plan_preventif_declencheur plan_preventif_declencheur[]

  @@index([parent_id], map: "famille_ibfk_parent")
}

model gamme {
  idGamme                    Int                          @id @default(autoincrement())
  code                       String?                      @db.VarChar(50)
  libelle                    String?                      @db.VarChar(100)
  typeMaintenance            String?                      @db.VarChar(50)
  actif                      Boolean?
  idModele                   Int?
  chargePrevue               Decimal?                     @db.Decimal(10, 2)
  etat                       String?                      @db.VarChar(50)
  jourFin                    Int?
  organisation               String?                      @db.VarChar(50)
  receptionTravaux           Boolean?                     @default(false)
  tempsArret                 Decimal?                     @db.Decimal(10, 2)
  modele                     modele?                      @relation(fields: [idModele], references: [idModele], onDelete: Restrict, onUpdate: Restrict, map: "gamme_ibfk_1")
  gamme_operation            gamme_operation[]
  intervention               intervention[]
  plan_preventif_declencheur plan_preventif_declencheur[]
  ppp_declencheur            ppp_declencheur[]

  @@index([idModele], map: "idModele")
}

model gamme_operation {
  idOperation            Int                      @id @default(autoincrement())
  ordre                  Int?
  libelle                String?                  @db.VarChar(100)
  tempsStandard          Int?
  idGamme                Int?
  description            String?                  @db.Text
  idFamille              Int?
  idMateriel             Int?
  idModele               Int?
  idPointStructure       Int?
  obligatoire            Boolean?                 @default(false)
  gamme                  gamme?                   @relation(fields: [idGamme], references: [idGamme], onDelete: Restrict, onUpdate: Restrict, map: "gamme_operation_ibfk_1")
  famille                famille?                 @relation("GammeOperationFamille", fields: [idFamille], references: [idFamille])
  materiel               materiel?                @relation("GammeOperationMateriel", fields: [idMateriel], references: [idMateriel])
  modele                 modele?                  @relation("GammeOperationModele", fields: [idModele], references: [idModele])
  point_structure        point_structure?         @relation("GammeOperationPointStructure", fields: [idPointStructure], references: [idPoint])
  operation_intervention operation_intervention[]

  @@index([idGamme], map: "idGamme")
  @@index([idPointStructure])
  @@index([idMateriel])
  @@index([idModele])
  @@index([idFamille])
}

model intervention {
  idIntervention Int @id @default(autoincrement())

  // =========================
  // Identification
  // =========================
  code        String? @unique @db.VarChar(50)
  libelle     String? @db.VarChar(150)
  description String? @db.Text

  // =========================
  // Classification CARL
  // =========================
  typeMaintenance    String? @db.VarChar(50) // CORRECTIF, PREVENTIF, CONDITIONNEL
  typeIntervention   String? @db.VarChar(50) // DIAGNOSTIC, TRAVAUX, CONTROLE...
  natureIntervention String? @db.VarChar(80) // CURATIF, CORRECTIF, PREVENTIF, SINISTRE...
  niveauMaintenance  String? @db.VarChar(30) // NIVEAU_1, NIVEAU_2...
  priorite           String? @default("NORMALE") @db.VarChar(30)
  criticite          String? @default("MOYENNE") @db.VarChar(30)
  centreCout         String? @db.VarChar(50)

  // =========================
  // Workflow / état
  // Etats conseillés :
  // EN_PREPARATION, ATTENTE_DEVIS, ATTENTE_VALIDATION,
  // ATTENTE_FOURNITURE, ATTENTE_REALISATION,
  // EN_COURS, TERMINE, SOLDE, ARCHIVE, ANNULE
  // =========================
  etat              String? @default("EN_PREPARATION") @db.VarChar(50)
  origineGeneration String? @db.VarChar(50) // DIRECTE, DI, PLAN_PREVENTIF, COMPTE_RENDU, ANOMALIE, MESURE

  // =========================
  // Liens principaux
  // =========================
  idMateriel                 Int?
  idPointStructure           Int?
  idDemande                  Int?
  idGamme                    Int?
  idEquipe                   Int?
  idPlanPreventif            Int?
  idPlanPreventifDeclencheur Int?
  idInterventionParent       Int?

  // =========================
  // Dates générales CARL
  // =========================
  dateDebut DateTime? @db.DateTime(0)
  dateFin   DateTime? @db.DateTime(0)

  dateDebutPrevue DateTime? @db.DateTime(0)
  dateFinPrevue   DateTime? @db.DateTime(0)
  dateDebutReelle DateTime? @db.DateTime(0)
  dateFinReelle   DateTime? @db.DateTime(0)

  dateSouhaiteeFin DateTime? @db.DateTime(0)
  dateLimite       DateTime? @db.DateTime(0)

  dateFixe   Boolean @default(false)
  aPlanifier Boolean @default(false)

  // =========================
  // Dates workflow
  // =========================
  dateAffectation DateTime? @db.DateTime(0)
  dateValidation  DateTime? @db.DateTime(0)
  dateCloture     DateTime? @db.DateTime(0)
  dateAnnulation  DateTime? @db.DateTime(0)
  dateArchivage   DateTime? @db.DateTime(0)
  dateReport      DateTime? @db.DateTime(0)

  // =========================
  // Charges / durées
  // =========================
  chargePrevue  Decimal? @db.Decimal(10, 2)
  chargeRevisee Decimal? @db.Decimal(10, 2)
  chargeReelle  Decimal? @db.Decimal(10, 2)

  chargePrevueMoyens  Decimal? @db.Decimal(10, 2)
  chargeReviseeMoyens Decimal? @db.Decimal(10, 2)
  chargeReelleMoyens  Decimal? @db.Decimal(10, 2)

  dureePrevue Decimal? @db.Decimal(10, 2)
  dureeReelle Decimal? @db.Decimal(10, 2)

  tempsArretPrevu Decimal? @db.Decimal(10, 2)
  tempsArretReel  Decimal? @db.Decimal(10, 2)

  // =========================
  // Etat matériel / disponibilité
  // =========================
  materielEnPanne      Boolean @default(false)
  materielIndisponible Boolean @default(false)
  arretMateriel        Boolean @default(false)
  arretProduction      Boolean @default(false)
  impactProduction     String? @db.VarChar(100)

  // =========================
  // Diagnostic / aide dépannage
  // =========================
  symptome          String? @db.VarChar(150)
  cause             String? @db.VarChar(150)
  remede            String? @db.VarChar(150)
  diagnosticInitial String? @db.Text
  instructions      String? @db.Text

  // =========================
  // Réception travaux
  // Si receptionTravaux = true :
  // EN_COURS -> TERMINE -> SOLDE
  // Si refus : TERMINE -> EN_COURS
  // =========================
  receptionTravaux     Boolean   @default(false)
  dateReceptionTravaux DateTime? @db.DateTime(0)
  receptionBy          String?   @db.VarChar(100)
  motifRefusTravaux    String?   @db.Text

  // =========================
  // Prestation / sous-traitance simple
  // Pour le détail, utiliser table sous_traitance_intervention
  // =========================
  prestataire    String? @db.VarChar(150)
  contrat        String? @db.VarChar(100)
  periodeContrat String? @db.VarChar(100)
  horsForfait    Boolean @default(false)

  // =========================
  // Garantie
  // =========================
  garantie     String? @db.VarChar(100)
  horsGarantie Boolean @default(false)

  // =========================
  // Mesure
  // =========================
  idPointMesure        Int?
  idReleveMesure       Int?
  valeurMesureActuelle Decimal? @db.Decimal(12, 2)

  // =========================
  // Commentaires / motifs
  // =========================
  commentairePlanification String? @db.Text
  commentairePriseEnCompte String? @db.Text
  commentaireRealisation   String? @db.Text
  motifMiseEnAttente       String? @db.Text
  motifAnnulation          String? @db.Text
  motifReport              String? @db.Text

  // =========================
  // Acteurs
  // =========================
  createdBy   String? @db.VarChar(100)
  assignedBy  String? @db.VarChar(100)
  plannedBy   String? @db.VarChar(100)
  startedBy   String? @db.VarChar(100)
  validatedBy String? @db.VarChar(100)
  closedBy    String? @db.VarChar(100)
  cancelledBy String? @db.VarChar(100)
  archivedBy  String? @db.VarChar(100)
  reportedBy  String? @db.VarChar(100)

  // =========================
  // Sécurité générale
  // Le détail peut être dans securite_intervention
  // =========================
  consignationRequise  Boolean @default(false)
  permisTravailRequis  Boolean @default(false)
  instructionsSecurite String? @db.Text

  // =========================
  // Coûts prévus / révisés / réels
  // CARL fige le prévu à la validation,
  // puis initialise le révisé.
  // =========================
  coutMainOeuvrePrevu  Decimal? @db.Decimal(10, 2)
  coutMainOeuvreRevise Decimal? @db.Decimal(10, 2)
  coutMainOeuvreReel   Decimal? @db.Decimal(10, 2)

  coutPiecesPrevu  Decimal? @db.Decimal(10, 2)
  coutPiecesRevise Decimal? @db.Decimal(10, 2)
  coutPiecesReel   Decimal? @db.Decimal(10, 2)

  coutMoyensPrevu  Decimal? @db.Decimal(10, 2)
  coutMoyensRevise Decimal? @db.Decimal(10, 2)
  coutMoyensReel   Decimal? @db.Decimal(10, 2)

  coutSousTraitancePrevu  Decimal? @db.Decimal(10, 2)
  coutSousTraitanceRevise Decimal? @db.Decimal(10, 2)
  coutSousTraitanceReel   Decimal? @db.Decimal(10, 2)

  coutTotalPrevu  Decimal? @db.Decimal(10, 2)
  coutTotalRevise Decimal? @db.Decimal(10, 2)
  coutTotalReel   Decimal? @db.Decimal(10, 2)

  // =========================
  // Audit
  // =========================
  createdAt                          DateTime                             @default(now())
  updatedAt                          DateTime                             @default(now()) @updatedAt @db.DateTime(0)
  // =========================
  // Relations existantes
  // =========================
  affectation_technicien             affectation_technicien[]
  consommations                      consommation[]
  historique_declenchement_preventif historique_declenchement_preventif[]
  operation_intervention             operation_intervention[]

  materiel                   materiel?                   @relation(fields: [idMateriel], references: [idMateriel], onDelete: Restrict, onUpdate: Restrict, map: "intervention_ibfk_1")
  demande_intervention       demande_intervention?       @relation(fields: [idDemande], references: [idDemande], onDelete: Restrict, onUpdate: Restrict, map: "intervention_ibfk_2")
  gamme                      gamme?                      @relation(fields: [idGamme], references: [idGamme], onDelete: Restrict, onUpdate: Restrict, map: "intervention_ibfk_3")
  equipe_maintenance         equipe_maintenance?         @relation(fields: [idEquipe], references: [idEquipe], onDelete: Restrict, onUpdate: Restrict, map: "intervention_ibfk_equipe")
  plan_preventif             plan_preventif?             @relation(fields: [idPlanPreventif], references: [idPlanPreventif])
  plan_preventif_declencheur plan_preventif_declencheur? @relation(fields: [idPlanPreventifDeclencheur], references: [idPlanPreventifDeclencheur])

  // Point de structure
  point_structure point_structure? @relation("InterventionPointStructure", fields: [idPointStructure], references: [idPoint], onDelete: Restrict, onUpdate: Restrict)

  // Association / intervention liée
  interventionParent   intervention?  @relation("InterventionParent", fields: [idInterventionParent], references: [idIntervention], onDelete: SetNull, onUpdate: Restrict)
  interventionsEnfants intervention[] @relation("InterventionParent")

  // Tables ajoutées précédemment
  compteRendu     compte_rendu_intervention?
  historiquesEtat historique_etat_intervention[]

  anomaliesDetectees anomalie_intervention[] @relation("InterventionOrigineAnomalie")
  anomaliesSuivies   anomalie_intervention[] @relation("InterventionSuiviAnomalie")

  // Tables filles conseillées pour les onglets CARL
  occupations    occupation_intervention[]
  moyens         moyen_intervention[]
  sousTraitances sous_traitance_intervention[]
  fournitures    fourniture_intervention[]
  adresses       adresse_intervention[]
  securites      securite_intervention[]
  sortieStocks   sortie_stock[]

  @@index([code])
  @@index([etat])
  @@index([typeMaintenance])
  @@index([natureIntervention])
  @@index([priorite])
  @@index([criticite])
  @@index([centreCout])
  @@index([dateDebut])
  @@index([dateFin])
  @@index([dateDebutPrevue])
  @@index([dateFinPrevue])
  @@index([dateDebutReelle])
  @@index([dateFinReelle])
  @@index([dateSouhaiteeFin])
  @@index([idDemande], map: "idDemande")
  @@index([idGamme], map: "idGamme")
  @@index([idMateriel], map: "idMateriel")
  @@index([idPointStructure])
  @@index([idEquipe], map: "intervention_ibfk_equipe")
  @@index([idPlanPreventif])
  @@index([idPlanPreventifDeclencheur])
  @@index([idInterventionParent])
  @@index([idPointMesure])
  @@index([idReleveMesure])
}

model materiel {
  idMateriel Int     @id @default(autoincrement())
  code       String? @unique @db.VarChar(50)
  libelle    String? @db.VarChar(150)

  numeroSerie String? @unique @db.VarChar(100)

  dateMiseService       DateTime? @db.Date
  dateDernierInventaire DateTime? @db.Date
  dateRebut             DateTime? @db.Date
  motifRebut            String?   @db.VarChar(255)

  gereEnStock Boolean @default(false)

  positionActuelle String? @db.VarChar(30)

  idModele           Int?
  idEtat             Int?
  idType             Int?
  idPointStructure   Int?
  idMaterielParent   Int?
  idLigneEntreeStock Int?

  actif Boolean? @default(true)

  modele           modele?             @relation(fields: [idModele], references: [idModele], onDelete: Restrict, onUpdate: Restrict, map: "materiel_ibfk_1")
  etat_materiel    etat_materiel?      @relation(fields: [idEtat], references: [idEtat], onDelete: Restrict, onUpdate: Restrict, map: "materiel_ibfk_2")
  type_materiel    type_materiel?      @relation(fields: [idType], references: [idType], onDelete: Restrict, onUpdate: Restrict, map: "materiel_ibfk_3")
  point_structure  point_structure?    @relation("PointStructureMateriels", fields: [idPointStructure], references: [idPoint], onDelete: SetNull, onUpdate: Restrict)
  entreeStockLigne entree_stock_ligne? @relation(fields: [idLigneEntreeStock], references: [idLigneEntreeStock], onDelete: SetNull)

  materielParent materiel?  @relation("MaterielParent", fields: [idMaterielParent], references: [idMateriel], onDelete: SetNull, onUpdate: Restrict)
  sousMateriels  materiel[] @relation("MaterielParent")

  demande_intervention               demande_intervention[]
  intervention                       intervention[]
  mouvementsStock                    mouvement_stock[]
  lignesInventairePrepare            LigneInventairePrepare[]
  lignesSortieStock                  sortie_stock_ligne[]
  gamme_operation                    gamme_operation[]                    @relation("GammeOperationMateriel")
  historique_declenchement_preventif historique_declenchement_preventif[]
  plan_preventif                     plan_preventif[]
  plan_preventif_declencheur         plan_preventif_declencheur[]
  points_mesure                      point_mesure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([idEtat], map: "idEtat")
  @@index([idModele], map: "idModele")
  @@index([idType], map: "idType")
  @@index([idPointStructure])
  @@index([idMaterielParent])
  @@index([idLigneEntreeStock])
}

model magasin {
  idMagasin                    Int                           @id @default(autoincrement())
  code                         String                        @unique @db.VarChar(50)
  libelle                      String                        @db.VarChar(100)
  actif                        Boolean                       @default(true)
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  demandes_reapprovisionnement demande_reapprovisionnement[] @relation("MagasinDemandesReapprovisionnement")
  demandesTransfertDestination demande_transfert_stock[]     @relation("DemandeTransfertDestination")
  demandesTransfertSource      demande_transfert_stock[]     @relation("DemandeTransfertSource")
  emplacements                 emplacement_magasin[]
  lignesEntreeStock            entree_stock_ligne[]
  inventairesPrepares          InventairePrepare[]
  mouvementsDest               mouvement_stock[]             @relation("MagasinDestination")
