  derniereRealisationPrevueValeur    Decimal?                             @db.Decimal(10, 2)
  symptomeCode                       String?                              @db.VarChar(50)
  saisonnaliteDu                     DateTime?                            @db.Date
  saisonnaliteAu                     DateTime?                            @db.Date
  actif                              Boolean?                             @default(true)
  createdAt                          DateTime                             @default(now())
  updatedAt                          DateTime                             @updatedAt
  idPointMesure                      Int?
  historique_declenchement_preventif historique_declenchement_preventif[]
  intervention                       intervention[]
  famille                            famille?                             @relation(fields: [idFamille], references: [idFamille])
  gamme                              gamme                                @relation(fields: [idGamme], references: [idGamme])
  materiel                           materiel?                            @relation(fields: [idMateriel], references: [idMateriel])
  modele                             modele?                              @relation(fields: [idModele], references: [idModele])
  plan_preventif                     plan_preventif                       @relation(fields: [idPlanPreventif], references: [idPlanPreventif])
  point_mesure                       point_mesure?                        @relation(fields: [idPointMesure], references: [idPointMesure], onUpdate: Restrict)
  point_structure                    point_structure?                     @relation(fields: [idPointStructure], references: [idPoint])
  ppp_declencheur                    ppp_declencheur?                     @relation(fields: [idPppDeclencheurSource], references: [idPppDeclencheur])

  @@index([idPlanPreventif])
  @@index([idPppDeclencheurSource])
  @@index([idGamme])
  @@index([idPointStructure])
  @@index([idMateriel])
  @@index([idModele])
  @@index([idFamille])
  @@index([idPointMesure])
}

model historique_declenchement_preventif {
  idHistoriqueDeclenchement  Int                        @id @default(autoincrement())
  idPlanPreventifDeclencheur Int
  idIntervention             Int?
  idMateriel                 Int?
  idPointStructure           Int?
  dateDeclenchement          DateTime                   @default(now())
  conditionResume            String?                    @db.Text
  valeurRealisation          Decimal?                   @db.Decimal(10, 2)
  fictif                     Boolean?                   @default(false)
  statut                     String?                    @db.VarChar(30)
  createdAt                  DateTime                   @default(now())
  intervention               intervention?              @relation(fields: [idIntervention], references: [idIntervention])
  materiel                   materiel?                  @relation(fields: [idMateriel], references: [idMateriel])
  plan_preventif_declencheur plan_preventif_declencheur @relation(fields: [idPlanPreventifDeclencheur], references: [idPlanPreventifDeclencheur])
  point_structure            point_structure?           @relation(fields: [idPointStructure], references: [idPoint])

  @@index([idPlanPreventifDeclencheur])
  @@index([idIntervention])
  @@index([idMateriel])
  @@index([idPointStructure])
}

model equipe_maintenance {
  idEquipe     Int            @id @default(autoincrement())
  code         String         @unique(map: "code") @db.VarChar(50)
  libelle      String?        @db.VarChar(100)
  heureDebut   DateTime?      @db.Time(0)
  heureFin     DateTime?      @db.Time(0)
  actif        Boolean?       @default(true)
  intervention intervention[]
  technicien   technicien[]
}

model type_equipement {
  idTypeEquipement Int      @id @default(autoincrement())
  code             String   @unique @db.VarChar(50)
  libelle          String   @db.VarChar(150)
  description      String?  @db.Text
  actif            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  modeles          modele[]
}

model fabricant {
  idFabricant Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  nom         String   @db.VarChar(150)
  pays        String?  @db.VarChar(100)
  telephone   String?  @db.VarChar(30)
  email       String?  @db.VarChar(150)
  siteWeb     String?  @db.VarChar(255)
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  marques     marque[]
  modeles     modele[]
}

model marque {
  idMarque    Int        @id @default(autoincrement())
  code        String     @unique @db.VarChar(50)
  libelle     String     @db.VarChar(150)
  description String?    @db.Text
  idFabricant Int?
  actif       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  fabricant   fabricant? @relation(fields: [idFabricant], references: [idFabricant], onUpdate: Restrict)
  modeles     modele[]

  @@index([idFabricant], map: "marque_idFabricant_fkey")
}

model modele_plan_preventif_predefini {
  idModelePlanPreventifPredefini Int                      @id @default(autoincrement())
  idModele                       Int
  idPlanPreventifPredefini       Int
  principal                      Boolean                  @default(false)
  actif                          Boolean                  @default(true)
  createdAt                      DateTime                 @default(now())
  modele                         modele                   @relation(fields: [idModele], references: [idModele], onDelete: Cascade)
  plan_preventif_predefini       plan_preventif_predefini @relation(fields: [idPlanPreventifPredefini], references: [idPlanPreventifPredefini], onDelete: Cascade)

  @@unique([idModele, idPlanPreventifPredefini])
  @@index([idModele])
  @@index([idPlanPreventifPredefini])
}

enum TypeFamille {
  EQUIPEMENT
  ARTICLE
  MIXTE
}

enum NatureAchatFamille {
  ELECTRIQUE
  MECANIQUE
  HYDRAULIQUE
  PNEUMATIQUE
  AUTOMATISME
  INFORMATIQUE
  GENERAL
}

enum StatutInventaire {
  BROUILLON
  EN_COMPTAGE
  VALIDE
  ANNULE
}

model compte_rendu_intervention {
  idCompteRendu  Int @id @default(autoincrement())
  idIntervention Int @unique

  dateCompteRendu DateTime @default(now())
  saisiPar        String?  @db.VarChar(100)

  travauxEffectues String? @db.Text
  diagnostic       String? @db.Text
  cause            String? @db.VarChar(150)
  remede           String? @db.VarChar(150)
  observation      String? @db.Text

  resultat    String?  @db.VarChar(50) // REPARE, NON_REPARE, PARTIEL
  tempsArret  Decimal? @db.Decimal(10, 2)
  dureeReelle Decimal? @db.Decimal(10, 2)

  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)

  @@index([idIntervention])
}

model historique_etat_intervention {
  idHistoriqueEtat Int @id @default(autoincrement())
  idIntervention   Int

  ancienEtat String? @db.VarChar(50)
  nouvelEtat String  @db.VarChar(50)

  action      String? @db.VarChar(100) // PLANIFIER, DEMARRER, TERMINER, CLOTURER...
  commentaire String? @db.Text

  changedBy String?  @db.VarChar(100)
  changedAt DateTime @default(now())

  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)

  @@index([idIntervention])
  @@index([nouvelEtat])
}

model historique_etat_demande_intervention {
  idHistoriqueEtat Int @id @default(autoincrement())
  idDemande        Int

  ancienStatut  String? @db.VarChar(50)
  nouveauStatut String  @db.VarChar(50)

  action      String? @db.VarChar(100)
  commentaire String? @db.Text

  changedBy String?  @db.VarChar(100)
  changedAt DateTime @default(now()) @db.DateTime(0)

  demande demande_intervention @relation(fields: [idDemande], references: [idDemande], onDelete: Cascade)

  @@index([idDemande])
  @@index([nouveauStatut])
}

model anomalie_intervention {
  idAnomalie            Int  @id @default(autoincrement())
  idInterventionOrigine Int
  idInterventionSuivi   Int?

  titre       String  @db.VarChar(150)
  description String? @db.Text
  criticite   String? @default("MOYENNE") @db.VarChar(30)
  urgence     String? @default("NORMALE") @db.VarChar(30)

  statut        String   @default("OUVERTE") @db.VarChar(50)
  detecteePar   String?  @db.VarChar(100)
  dateDetection DateTime @default(now())

  actionRecommandee String? @db.Text

  interventionOrigine intervention  @relation("InterventionOrigineAnomalie", fields: [idInterventionOrigine], references: [idIntervention], onDelete: Cascade)
  interventionSuivi   intervention? @relation("InterventionSuiviAnomalie", fields: [idInterventionSuivi], references: [idIntervention])

  @@index([idInterventionOrigine])
  @@index([idInterventionSuivi])
  @@index([statut])
}

model occupation_intervention {
  idOccupation   Int  @id @default(autoincrement())
  idIntervention Int
  idTechnicien   Int?
  idOperation    Int?

  dateOccupation DateTime @db.DateTime(0)
  duree          Decimal  @db.Decimal(10, 2) // en heures

  natureOccupation String? @db.VarChar(80) // NORMAL, DEPLACEMENT, DEPANNAGE...
  typeHoraire      String? @db.VarChar(80) // JOURNEE, NUIT, HS...
  commentaire      String? @db.Text

  createdBy String?  @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  intervention intervention            @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)
  technicien   technicien?             @relation(fields: [idTechnicien], references: [idTechnicien], onDelete: SetNull)
  operation    operation_intervention? @relation(fields: [idOperation], references: [idOperation], onDelete: SetNull)

  @@index([idIntervention])
  @@index([idTechnicien])
  @@index([idOperation])
  @@index([dateOccupation])
}

model moyen_intervention {
  idMoyenIntervention Int @id @default(autoincrement())
  idIntervention      Int

  codeMoyen   String? @db.VarChar(50)
  designation String  @db.VarChar(150)
  typeMoyen   String? @db.VarChar(80)

  quantite    Decimal? @db.Decimal(10, 2)
  dureePrevue Decimal? @db.Decimal(10, 2)
  dureeReelle Decimal? @db.Decimal(10, 2)

  coutPrevu Decimal? @db.Decimal(10, 2)
  coutReel  Decimal? @db.Decimal(10, 2)

  commentaire String? @db.Text

  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)

  @@index([idIntervention])
}

model sous_traitance_intervention {
  idSousTraitance Int @id @default(autoincrement())
  idIntervention  Int

  prestataire String? @db.VarChar(150)
  service     String? @db.VarChar(150)
  description String? @db.Text

  datePrevue DateTime? @db.DateTime(0)
  dateReelle DateTime? @db.DateTime(0)

  coutPrevu  Decimal? @db.Decimal(10, 2)
  coutRevise Decimal? @db.Decimal(10, 2)
  coutReel   Decimal? @db.Decimal(10, 2)

  statut String? @default("PREVU") @db.VarChar(50)

  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)

  @@index([idIntervention])
}

model fourniture_intervention {
  idFourniture   Int  @id @default(autoincrement())
  idIntervention Int
  idArticle      Int?

  designation String? @db.VarChar(150)
  source      String? @db.VarChar(50) // STOCK, ACHAT_DIRECT

  quantitePrevue  Decimal? @db.Decimal(10, 2)
  quantiteRevisee Decimal? @db.Decimal(10, 2)
  quantiteReelle  Decimal? @db.Decimal(10, 2)

  coutPrevu  Decimal? @db.Decimal(10, 2)
  coutRevise Decimal? @db.Decimal(10, 2)
  coutReel   Decimal? @db.Decimal(10, 2)

  statut String? @default("PREVU") @db.VarChar(50)

  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)
  article      article?     @relation(fields: [idArticle], references: [idArticle], onDelete: SetNull)

  @@index([idIntervention])
  @@index([idArticle])
}

model adresse_intervention {
  idAdresseIntervention Int @id @default(autoincrement())
  idIntervention        Int

  typeAdresse String? @db.VarChar(50)
  adresse     String? @db.VarChar(255)
  ville       String? @db.VarChar(100)
  pays        String? @db.VarChar(100)
  commentaire String? @db.Text

  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)

  @@index([idIntervention])
}

model securite_intervention {
  idSecurite     Int @id @default(autoincrement())
  idIntervention Int

  typeElement String? @db.VarChar(50) // RISQUE, PREVENTION, CONSIGNE
  libelle     String  @db.VarChar(150)
  description String? @db.Text

  obligatoire Boolean @default(false)
  realise     Boolean @default(false)

  intervention intervention @relation(fields: [idIntervention], references: [idIntervention], onDelete: Cascade)

  @@index([idIntervention])
}
